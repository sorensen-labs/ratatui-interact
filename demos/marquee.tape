# Marquee Demo - scrolling text animations
Source demos/settings.tape
Output demos/gifs/marquee.gif

Hide
Type "cargo run --example marquee_demo"
Enter
Sleep 5s
Show

# Watch scrolling animations
Sleep 3s

# Pause all
Space
Sleep 1s

# Resume
Space
Sleep 1s

# Increase speed
Type "+"
Sleep 500ms
Type "+"
Sleep 1s

# Decrease speed
Type "-"
Sleep 500ms
Type "-"
Sleep 500ms
Type "-"
Sleep 1s

# Reset
Type "r"
Sleep 2s

Type "q"
